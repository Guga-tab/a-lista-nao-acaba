[gd_scene format=3 uid="uid://b4vrhnreif8jq"]

[sub_resource type="GDScript" id="GDScript_n1e1k"]
script/source = "extends Control

var is_open = false

func _ready():
	close()
	
func open():
	visible = true
	is_open = true
	
func _process(delta):
	if Input.is_action_just_pressed(\"i\"):
		if is_open:
			close()
		else:
			open()
	
func close():
	visible = false
	is_open = false
	
"

